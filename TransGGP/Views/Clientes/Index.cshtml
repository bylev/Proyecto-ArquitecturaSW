@model List<TransGGP.Domain.Models.Cliente>

<h1>Clientes</h1>

<a asp-action="Create" class="btn btn-primary mb-3">+ Nuevo cliente</a>
<a asp-action="Reporte" asp-route-formato="texto" class="btn btn-outline-secondary mb-3" target="_blank">Reporte texto</a>
<a asp-action="Reporte" asp-route-formato="csv" class="btn btn-outline-secondary mb-3" target="_blank">Reporte CSV</a>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Id</th>
            <th>Nombre</th>
            <th>Fecha de creación</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var cliente in Model)
        {
            <tr>
                <td>@cliente.Id</td>
                <td>@cliente.Nombre</td>
                <td>@cliente.FechaCreacion.ToShortDateString()</td>
                <td>
                    <form asp-action="Delete" method="post" onsubmit="return confirm('¿Eliminar este cliente?');">
                        <input type="hidden" name="id" value="@cliente.Id" />
                        <button type="submit" class="btn btn-danger btn-sm">Eliminar</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
