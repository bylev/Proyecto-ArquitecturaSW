@model TransGGP.Domain.Models.Servicio

<h1>Registrar Servicio</h1>

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label class="form-label">Cliente</label>
        <select asp-for="ClienteId" class="form-select" asp-items="ViewBag.Clientes">
            <option value="">-- Selecciona un cliente --</option>
        </select>
    </div>
    <div class="mb-3">
        <label class="form-label">Operador</label>
        <select asp-for="OperadorId" class="form-select" asp-items="ViewBag.Operadores">
            <option value="">-- Selecciona un operador --</option>
        </select>
    </div>
    <div class="mb-3">
        <label class="form-label">Unidad</label>
        <select asp-for="UnidadId" class="form-select" asp-items="ViewBag.Unidades">
            <option value="">-- Selecciona una unidad --</option>
        </select>
    </div>

    <div class="mb-3">
        <label asp-for="NumeroEmbarque" class="form-label">Número de embarque</label>
        <input asp-for="NumeroEmbarque" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Origen" class="form-label">Origen</label>
        <input asp-for="Origen" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Destino" class="form-label">Destino</label>
        <input asp-for="Destino" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="TipoCarga" class="form-label">Tipo de carga</label>
        <input asp-for="TipoCarga" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="FechaCarga" class="form-label">Fecha de carga</label>
        <input asp-for="FechaCarga" type="date" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="FechaEntrega" class="form-label">Fecha de entrega</label>
        <input asp-for="FechaEntrega" type="date" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Estatus" class="form-label">Estatus</label>
        <input asp-for="Estatus" class="form-control" placeholder="Pendiente, En tránsito, Completado" />
    </div>

    <button type="submit" class="btn btn-primary">Guardar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>
