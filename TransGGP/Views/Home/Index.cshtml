@{
    ViewData["Title"] = "Inicio";
}

<section class="row align-items-center py-5">
    <div class="col-lg-6 text-center text-lg-start">
        <p class="text-uppercase mb-3" style="letter-spacing:4px; font-size:.95rem; color:var(--ggp-muted);">
            Sistema de gestión de transporte
        </p>
        <h1 class="display-3" style="border:0; font-size:3.6rem;">
            <span id="typed"></span><span class="type-cursor">|</span>
        </h1>
        <p class="lead mt-4" style="max-width:560px; font-size:1.3rem; color:var(--ggp-muted);">
            Plataforma para registrar y administrar los servicios de transporte de carga,
            sus clientes, operadores y unidades, con un historial confiable para el
            análisis y crecimiento del negocio.
        </p>
        <div class="mt-4">
            <a asp-controller="Servicios" asp-action="Index" class="btn-hero">Registrar servicio <span class="arrow">&rarr;</span></a>
            <a asp-controller="Clientes" asp-action="Index" class="btn-text">Ver clientes <span class="arrow">&rarr;</span></a>
        </div>
    </div>
    <div class="col-lg-6 text-center mt-5 mt-lg-0">
        <img src="~/images/logo2.png" alt="Transportes GGP" class="hero-logo" />
    </div>
</section>

<hr style="border-color:var(--ggp-line); max-width:220px; margin:1rem auto 3.5rem;" />

<section class="row g-4 pb-5">
    <div class="col-md-3">
        <a asp-controller="Servicios" asp-action="Index" class="modulo-card">
            <h3>Servicios</h3>
            <p>Registro de cada viaje con su cliente, operador y unidad.</p>
        </a>
    </div>
    <div class="col-md-3">
        <a asp-controller="Clientes" asp-action="Index" class="modulo-card">
            <h3>Clientes</h3>
            <p>Catálogo de clientes del negocio.</p>
        </a>
    </div>
    <div class="col-md-3">
        <a asp-controller="Operadores" asp-action="Index" class="modulo-card">
            <h3>Operadores</h3>
            <p>Choferes asignados a los servicios.</p>
        </a>
    </div>
    <div class="col-md-3">
        <a asp-controller="Unidades" asp-action="Index" class="modulo-card">
            <h3>Unidades</h3>
            <p>Tractocamiones y equipo de transporte.</p>
        </a>
    </div>
</section>

@section Scripts {
    <script>
        (function () {
            var texto = "Transportes GGP";
            var destino = document.getElementById("typed");
            var i = 0;
            function escribir() {
                if (i <= texto.length) {
                    destino.textContent = texto.substring(0, i);
                    i++;
                    setTimeout(escribir, 110);   // velocidad del tipeo
                }
            }
            escribir();
        })();
    </script>
}
